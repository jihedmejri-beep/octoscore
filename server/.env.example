# ---------------------------------------------------------------------------
# OctoScore API — environment variables
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ---------------------------------------------------------------------------

# --- Server ---
PORT=5000
NODE_ENV=development

# Optional: production error tracking. Create a free project at sentry.io,
# choose "Node.js", paste the DSN here (and into Render's env vars). Leave blank
# to disable — Sentry stays completely inactive until this is set.
SENTRY_DSN=
# Comma-separated list of allowed frontend origins (Vercel + local dev).
# Use "*" to allow any origin (not recommended in production).
CLIENT_URL=http://localhost:5173,http://localhost:5174

# --- MongoDB ---
# Local (MongoDB Community Server):  mongodb://127.0.0.1:27017/octoscore
# Atlas (cloud):  mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/octoscore
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/octoscore?appName=Cluster0

# --- Auth (JWT) ---
# Make this a long, random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=30d

# --- First admin account (created by `npm run seed`) ---
# Use a strong, unique password — this is the initial admin login.
ADMIN_NAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# --- Cloudinary (gallery image hosting + downloads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=octoscore/gallery

# --- AI quiz generation (optional) ---
# When LLM_BASE_URL is set, the quiz auto-refreshes once a day with fresh Arabic
# football-trivia questions. Leave it blank to manage questions by hand in the
# admin panel (no AI calls are made). Works with any OpenAI-compatible endpoint;
# uncomment ONE of the providers below. Free tiers are plenty for ~1 call/day.
#
# Groq (recommended: free, hosted, fast — key at https://console.groq.com/keys)
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Google Gemini (free tier — key at https://aistudio.google.com/apikey)
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.0-flash
#
# OpenRouter (one key, many free ":free" models — https://openrouter.ai/keys)
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Ollama (100% free, local dev only — no API key needed; run `ollama serve`)
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=qwen2.5
#
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
# Difficulty mix per quiz (auto-refreshes once a day). Defaults to 2/3/2 = 7
# questions, ordered easy → medium → hard. Keep the total small (≤7) on free
# tiers so generation + the fact-check pass stay under the per-minute limit.
QUIZ_EASY=2
QUIZ_MEDIUM=3
QUIZ_HARD=2
# Lower = more factual / less random (0.0–1.0). Keep low for trivia accuracy.
QUIZ_TEMPERATURE=0.3
# A second LLM pass fact-checks every answer before saving. Set to false to skip
# it (one fewer API call per refresh, but lower accuracy).
QUIZ_VERIFY=true
# Tip: if answers are still wrong, try a stronger model — e.g. on Groq set
# LLM_MODEL=openai/gpt-oss-120b (see https://console.groq.com/docs/models).
