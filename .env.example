# OctoScore frontend (Vite) — copy to ".env" for local dev.
# In production (Vercel), set this to your Railway API URL, e.g.
#   https://octoscore-api.up.railway.app
VITE_API_URL=http://localhost:5000

# Optional: production error tracking. Create a free project at sentry.io,
# choose "React", copy the DSN here (and into Vercel's env vars). Leave blank
# to disable — no Sentry code ships to users until this is set.
VITE_SENTRY_DSN=
